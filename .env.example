# K3D and Helm configuration for local development
# Copy this file to .env and fill in your values

# Google Sheets Configuration
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_NAME=Sheet1

# Service Account JSON (REQUIRED)
# Provide the service account JSON as a base64-encoded string.
# This avoids all shell escaping issues with special characters and literal \n in the private_key field.
# 
# To create the base64-encoded value:
# On Linux/Mac: base64 -w 0 service-account.json
# On Windows (PowerShell): [Convert]::ToBase64String([System.IO.File]::ReadAllBytes("service-account.json"))
# On Windows (Git Bash): base64 -w 0 service-account.json
#
# Then set the variable (no quotes needed):
SERVICE_ACCOUNT_JSON_BASE64=your_base64_encoded_service_account_json_here

# Optional: Override default values
# Note: Do NOT use quotes around these values - the Makefile will handle quoting
# SCHEDULE=*/5 * * * *
# TIME_LOCATION=Europe/Berlin
# RETENTION_TIME=24h

# SMTP configuration for go-mail-service
# EMAIL_SMTP_HOST=go-mail-service.notify.svc.cluster.local
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=reminders@example.com
# EMAIL_TO=recipient@example.com
# In K3D point at the host machine:
# EMAIL_SMTP_HOST=host.k3d.internal
